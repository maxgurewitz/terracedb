{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "CodexReviewResult",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "status",
    "summary",
    "blocking_findings",
    "warnings",
    "full_review_markdown"
  ],
  "properties": {
    "status": {
      "type": "string",
      "enum": ["pass", "fail"]
    },
    "summary": {
      "type": "string",
      "minLength": 1
    },
    "blocking_findings": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "warnings": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "full_review_markdown": {
      "type": "string",
      "minLength": 1
    }
  }
}
